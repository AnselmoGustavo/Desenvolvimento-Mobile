{
  "name": "flora-yamaguti-app",
  "version": "1.0.0",
  "description": "Aplicativo desktop para gestao de pedidos",
  "author": "Noemi Yamaguti, Gustavo Anselmo",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "package": "electron-builder --win nsis",
    "electron:build": "npm run build && electron ."
  },
  "build": {
    "appId": "com.flora.yamaguti",
    "productName": "Flora Yamaguti",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "./assets/icon.jpg"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
